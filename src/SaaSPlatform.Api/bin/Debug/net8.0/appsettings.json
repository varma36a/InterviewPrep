{
  "ConnectionStrings": {
    "AppDb": "Host=localhost;Port=5432;Database=saas_platform;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "SaaSPlatform",
    "Audience": "SaaSPlatformClients",
    "SigningKey": "SuperSecretSigningKeyValueWith32Chars!",
    "AccessTokenMinutes": 60
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:4317"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
